<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="https://local.smarttv/iptv-player"
        version="1.0.0"
        viewmodes="maximized">
    <tizen:application id="IPTVply001.IPTVPlayer" package="IPTVply001" required_version="2.3"/>
    <name>IPTV Player</name>
    <description>Simple IPTV playlist player for Samsung Tizen TV.</description>
    <author email="local@example.com" href="https://local.smarttv">Local</author>
    <content src="index.html"/>
    <icon src="icon.png"/>
    <feature name="http://tizen.org/feature/screen.size.normal.1080.1920"/>
    <tizen:metadata key="http://samsung.com/tv/metadata/prelaunch.support" value="true"/>
    <tizen:privilege name="http://tizen.org/privilege/internet"/>
    <tizen:privilege name="http://tizen.org/privilege/application.launch"/>
    <access origin="*" subdomains="true"/>
    <tizen:profile name="tv-samsung"/>
    <tizen:setting screen-orientation="landscape"
                   context-menu="disable"
                   background-support="disable"
                   encryption="disable"
                   install-location="auto"
                   hwkey-event="enable"/>
</widget>
